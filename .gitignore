# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ─────────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─────────────────────────────────────────────
# Secrets / Environment
# ─────────────────────────────────────────────
.env
*.env
!.env.example
token
secrets.toml

# ─────────────────────────────────────────────
# Runtime data
# Ignore everything by default
# ─────────────────────────────────────────────
data/*

# Keep scripts
!data/generate_dataset.py
!data/load_real_data.py
!data/.gitkeep

# Keep deployment CSVs (IMPORTANT)
!data/scored_headlines.csv
!data/temporal_risk.csv
!data/risk_summary.csv
!data/source_summary.csv

# Ignore temporary/generated extras
data/.seen_hashes.json
data/.phrasebank_downloaded
data/FinancialPhraseBank/
data/__pycache__/
data/batch_state.json
data/financial_news.csv
data/all-data.csv
data/phrasebank_eval.csv

# ─────────────────────────────────────────────
# Models (hosted on Hugging Face)
# ─────────────────────────────────────────────
models/*
!models/.gitkeep

*.bin
*.pt
*.pth
*.safetensors
checkpoints/

# ─────────────────────────────────────────────
# HuggingFace / Transformers cache
# ─────────────────────────────────────────────
.huggingface/
.cache/
hf_cache/
transformers_cache/

# ─────────────────────────────────────────────
# Databases
# ─────────────────────────────────────────────
db/
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────
# Streamlit cache
# ─────────────────────────────────────────────
.streamlit/
.streamlit/cache/

# ─────────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────────
notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints

# ─────────────────────────────────────────────
# OS / Editor files
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# ─────────────────────────────────────────────
# Build artifacts
# ─────────────────────────────────────────────
*.egg-info/
dist/
build/

# Optional utility scripts
upload_model.py