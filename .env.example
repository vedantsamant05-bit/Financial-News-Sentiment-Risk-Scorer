# ─── API Keys ─────────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
GNEWS_KEY=your_gnews_key_here
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# ─── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (default — no extra setup needed):
DATABASE_URL=sqlite:///db/finrisk.db

# PostgreSQL example (uncomment and fill in for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/finrisk

# ─── Model ────────────────────────────────────────────────────────────────────
SENTIMENT_MODEL=ProsusAI/finbert
FINE_TUNED_MODEL_PATH=models/finbert-finetuned

# ─── Risk thresholds ─────────────────────────────────────────────────────────
RISK_THRESHOLD=0.5
ALERT_SCORE_THRESHOLD=30.0

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
